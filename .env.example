# Azure OpenAI (required for azure_whisper and azure_gpt4o backends)
AZURE_API_KEY=your-azure-api-key-here
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-12-01-preview

# Local WhisperX (optional, required for local_whisper backend)
# LOCAL_WHISPER_API_BASE=http://your-server:8080
# LOCAL_WHISPER_API_KEY=your-local-api-key

# Optional: direct OpenAI (not used by default)
# OPENAI_API_KEY=sk-...
